FROM python:3.11-slim-bookworm

WORKDIR /app

# System deps + Node.js in one layer (changes rarely → stays cached)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    cmake \
    curl \
    autoconf \
    libpq-dev \
    python3-venv \
    cron \
    supervisor \
    libmupdf-dev \
    mupdf-tools \
    tesseract-ocr \
    libtesseract-dev \
    wkhtmltopdf \
    pandoc \
    fonts-dejavu \
    fonts-liberation \
    xfonts-base \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Node packages (changes rarely → stays cached)
RUN npm install -g pptxgenjs@3.12.0 docx

# Create venv (changes rarely → stays cached)
RUN python3 -m venv /app/venv

# Install Python deps BEFORE copying code
# This layer is only rebuilt when requirements files change
COPY requirements/base.txt requirements/base.txt
COPY requirements/dev.txt requirements/dev.txt

RUN . /app/venv/bin/activate && \
    pip install --no-cache-dir -r requirements/base.txt && \
    pip install --no-cache-dir -r requirements/dev.txt

# Download spaCy model (sm = ~50MB vs lg = ~750MB)
RUN . /app/venv/bin/activate && python -m spacy download en_core_web_sm

# Copy application code last — only this layer rebuilds on code changes
COPY . /app
RUN mkdir -p logs

ENV LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    QT_QPA_PLATFORM=offscreen

EXPOSE 8000

CMD ["/app/venv/bin/gunicorn", "--timeout", "120", "-w", "1", "-k", "eventlet", "-b", "0.0.0.0:8000", "--log-level", "debug", "src.trmeric_api.app.App:app"]
