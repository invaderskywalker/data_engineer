# ─────────────────────────────────────────
# PostgreSQL  (the database users connect)
# ─────────────────────────────────────────
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_KEY=sk-...

# ─────────────────────────────────────────
# AWS S3  (stores exported sheets / charts)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1

# ─────────────────────────────────────────
# MongoDB  (job queue / background tasks)
# ─────────────────────────────────────────
MONGO_USER=
MONGO_PASSWORD=
MONGO_DATABASE=ai_data_engineer

# ─────────────────────────────────────────
# Environment
# ─────────────────────────────────────────
# Options: dev | prod
ENVIRONMENT=dev

# ─────────────────────────────────────────
# Internal services
# ─────────────────────────────────────────
# Vector store service (semantic search)
VECTORSTORE_ENDPOINT=http://localhost:8001

# Django backend (notifications, roadmap/idea creation)
DJANGO_BACKEND_URL=http://localhost:8000/

# Web scraping microservice (optional)
SCRAPING_MACHINE_INTERNAL_ENDPOINT=http://localhost:8002/
SCRAPING_MACHINE_KEY=
